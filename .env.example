# Quest Board Bot — environment variables
# Copy to .env and fill in all required values before starting the bot.
# Generate secrets with: openssl rand -hex 32

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-bot-token-here
# Required Gateway Intents (Discord Developer Portal → Bot → Privileged Gateway Intents):
#   ✅ Message Content Intent
#   ✅ Server Members Intent (optional, for display names)
# Required OAuth2 scopes: bot + applications.commands
# Required bot permissions: Read Messages, Send Messages, Add Reactions,
#   Send Messages in Threads, Connect, Speak

# ── Quest Board API ───────────────────────────────────────────────────────────
QUESTBOARD_API_URL=http://questboard-backend:8000
BOT_API_KEY=replace-with-openssl-rand-hex-32
# Must match the key set in Quest Board Admin → Bot Settings → Bot API Key.
# Rotate independently with: openssl rand -hex 32

# ── HTTP server ───────────────────────────────────────────────────────────────
# The bot exposes an HTTP server on this port for incoming Quest Board calls.
# Set QUESTBOARD_BOT_URL=http://<this-host>:${HTTP_PORT} in Quest Board's .env.
HTTP_PORT=8080

# ── Linking ───────────────────────────────────────────────────────────────────
QUESTBOARD_PUBLIC_URL=https://questboard.example.com
# Used to construct the /auth/link?token=... URL sent to users in DMs.

# ── Transcription ─────────────────────────────────────────────────────────────
WHISPER_MODE=local              # 'local' or 'api'
# WHISPER_MODE=local requires the whisper profile:
#   docker compose --profile whisper up -d
# Can also be overridden in Quest Board Admin → Bot Settings.
WHISPER_API_URL=http://whisper:9000
OPENAI_API_KEY=                 # Only if WHISPER_MODE=api

# ── Summarisation ─────────────────────────────────────────────────────────────
SUMMARISER_MODE=ollama          # 'ollama' or 'api'
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3
ANTHROPIC_API_KEY=              # Only if SUMMARISER_MODE=api (Anthropic)
# OPENAI_API_KEY already set above — also used if SUMMARISER_MODE=api (OpenAI)

# ── Audio ─────────────────────────────────────────────────────────────────────
AUDIO_TEMP_DIR=/tmp/questboard-audio
MAX_RECORDING_HOURS=6

# ── Redis (optional) ──────────────────────────────────────────────────────────
# Used for message→session ID mapping (voting) and linking token polling.
# Falls back to in-memory dict if blank (messages lost on bot restart).
REDIS_URL=
